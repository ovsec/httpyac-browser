{
  "manifest_version": 3,
  "name": "HTTP Scanner",
  "version": "1.0.0",
  "description": "Scan webpage for httpyac HTTP requests. Run all or individually. Green/red icon status.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "HTTP Scanner"
  }
}
